{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Focus Synergy",
  "version": "0.1.0",
  "identifier": "com.focussynergy.desktop",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node scripts/static-server.js",
    "beforeBuildCommand": "node scripts/build-frontend.js"
  },
  "app": {
    "windows": [
      {
        "title": "Focus Synergy",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "windows": {
      "certificateThumbprint": null,
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "signingIdentity": "TODO_APPLE_DEVELOPMENT_IDENTITY",
      "entitlements": null,
      "exceptionDomain": null,
      "providerShortName": null
    },
    "category": "Productivity",
    "shortDescription": "Track focus loops and build lasting habits",
    "longDescription": "Focus Synergy is a lightweight desktop workspace to log deep work sessions, maintain consistency streaks, and audit productivity metrics."
  },
  "plugins": {
    "updater": {
      "pubkey": "TODO_TAURI_UPDATER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/MisbahHaq/Focus-Synergy/releases/latest/download/latest.json"
      ]
    }
  }
}
