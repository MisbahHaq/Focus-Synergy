rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      // User profile document
      allow read, write: if isOwner(uid);

      // Items (topics / habits)
      match /items/{itemId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid)
          && (
            !('accumulatedSeconds' in request.resource.data)
            || (request.resource.data.accumulatedSeconds is number && request.resource.data.accumulatedSeconds >= 0)
          )
          && (
            !('isRunning' in request.resource.data)
            || request.resource.data.isRunning == false
            || (
              request.resource.data.isRunning == true
              && get(/databases/$(database)/documents/users/$(uid)/meta/activeTimer).data.itemId == itemId
            )
          );
      }

      // Session logs
      match /logs/{logId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid)
          && (
            !('seconds' in request.resource.data)
            || (request.resource.data.seconds is number && request.resource.data.seconds >= 0)
          );
      }

      // Notes workspace
      match /notes/{noteId} {
        allow read, write: if isOwner(uid);
      }

      // Seasons
      match /seasons/{seasonId} {
        allow read, write: if isOwner(uid);
      }

      // Backlog entries
      match /backlog/{entryId} {
        allow read, write: if isOwner(uid);
      }

      // Daily energy mode logs
      match /dailyLogs/{logId} {
        allow read, write: if isOwner(uid);
      }

      // Habit completion logs
      match /habitLogs/{logId} {
        allow read, write: if isOwner(uid);
      }

      // Metadata collection (activeTimer, settings, etc.)
      match /meta/{metaId} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}
